#backward selection

full_add <- lm(Addicted_Score ~ 
                 Age + Gender + Social_Media_Hours + Sleep_Hours + 
                 Mental_Health_Score + Conflicts_Over_Social_Media +
                 Academic_Level + Country + Social_Media_Intensity +
                 Most_Used_Platform + Affects_Academic_Performance,
               data = Addiction,
               na.action = na.omit)
