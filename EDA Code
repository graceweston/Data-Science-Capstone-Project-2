#stat analysis
add_mod <- lm(Addicted_Score ~ 
                Age + Gender + Social_Media_Hours + Sleep_Hours + 
                Mental_Health_Score + Conflicts_Over_Social_Media,
              data = Addiction)

summary(add_mod)

#backward selection

full_add <- lm(Addicted_Score ~ 
                 Age + Gender + Social_Media_Hours + Sleep_Hours + 
                 Mental_Health_Score + Conflicts_Over_Social_Media +
                 Academic_Level + Country + Social_Media_Intensity +
                 Most_Used_Platform + Affects_Academic_Performance,
               data = Addiction,
               na.action = na.omit)
backward_mod <- step(full_add, direction = "backward")
summary(backward_mod)

#best model
best_add <- lm(Addicted_Score ~ 
                 Sleep_Hours + 
                 Mental_Health_Score + 
                 Conflicts_Over_Social_Media + 
                 Most_Used_Platform,
               data = Addiction,
               na.action = na.omit)
Addiction$Predicted_Addiction <- predict(best_add, newdata = Addiction)
new_person <- data.frame(
  Sleep_Hours = 6,
  Mental_Health_Score = 5,
  Conflicts_Over_Social_Media = 3,
  Most_Used_Platform = "Instagram"
)

predict(best_add, newdata = new_person)

#predicted best model
coef(best_add)
Addiction$Predicted_Addiction <- predict(best_add, newdata = Addiction)

#full interactions model
Addiction_clean <- Addiction |>
  select(-Student_ID, -Predicted, -Predicted_Addiction)

interaction_clean <- lm(Addicted_Score ~ 
                          (Sleep_Hours + Mental_Health_Score + 
                             Conflicts_Over_Social_Media + 
                             Most_Used_Platform + Age + Gender)^2,
                        data = Addiction_clean,
                        na.action = na.omit)

summary(interaction_clean)

coefs <- summary(interaction_clean)$coefficients
interaction_terms <- coefs[grep(":", rownames(coefs)), ]
interaction_terms[interaction_terms[,4] < 0.05, ]


# interactions model
interaction_mod <- lm(Addicted_Score ~ 
                        Sleep_Hours * Mental_Health_Score +
                        Conflicts_Over_Social_Media * Mental_Health_Score +
                        Sleep_Hours * Most_Used_Platform,
                      data = Addiction,
                      na.action = na.omit)

summary(interaction_mod)
anova(best_add, interaction_mod)

