#Checking distributions
library(ggplot2)
dev.off()

#Performance
ggplot(Performance, aes(x = GPA)) +
  geom_histogram(bins = 20)

ggplot(Performance, aes(x = Social_Media_Hours)) +
  geom_histogram(bins = 20)

ggplot(Performance, aes(x = Study_Hours_per_Day)) +
  geom_histogram(bins = 20)

ggplot(Performance, aes(x = Sleep_Hours)) +
  geom_histogram(bins = 20)

# Correlation matrix (numeric variables only)
cor_matrix <- cor(Performance[, sapply(Performance, is.numeric)], 
                  use = "complete.obs")

# Install if needed
install.packages("corrplot")
library(corrplot)

# Heatmap
corrplot(cor_matrix, method = "color", type = "upper", 
         tl.col = "black", tl.cex = 0.8)

cor.test(Performance$Social_Media_Hours, Performance$GPA)

gpamod <- lm(GPA ~ ., data = Performance)
summary(gpamod)

#Categorical summaries
table(Performance$Gender)
table(Performance$Age)
table(Performance$Social_Media_Intensity)

#Relationships 
ggplot(Performance, aes(x = Social_Media_Hours, y = GPA)) +
  geom_point() +
  geom_smooth(method = "lm")

ggplot(Performance, aes(x = Study_Hours_per_Day, y = GPA)) +
  geom_point() +
  geom_smooth(method = "lm")

# Run multiple regression
Perfmod <- lm(GPA ~ Study_Hours_per_Day + Sleep_Hours + Social_Media_Hours +
                Age + Assignments_Completed, data = Performance)

# View results
summary(Perfmod)

plot(Performance$Study_Hours_per_Day, Performance$GPA)
abline(lm(GPA ~ Study_Hours_per_Day, data = Performance))

plot(Performance$Sleep_Hours, Performance$GPA)
abline(lm(GPA ~ Sleep_Hours, data = Performance))

plot(Performance$Social_Media_Hours, Performance$GPA)
abline(lm(GPA ~ Social_Media_Hours, data = Performance))

#forward selection
fullmod <- lm(GPA ~ ., data = Performance)
nullmod <- lm(GPA ~ 1, data = Performance) # the 1 = intercept
summary(nullmod)

#backward selection
stepmod <- step(fullmod)
summary(stepmod)


#predicted model on Performance
# Build regression model
model2 <- lm(GPA ~ Age + Gender + Social_Media_Hours + Sleep_Hours + Attendance + Assignments_Completed + Midterm_Score, data = Performance)
# View results
summary(model2)

Performance$Predicted_GPA <- predict(model2)

#test example
new_student <- data.frame(
  Age = 20,
  Gender = 0,
