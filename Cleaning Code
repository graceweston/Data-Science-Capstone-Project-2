# Performance DataSet

# changing the GPA scale from 10 to 4
library(dplyr)
Performance <- Performance |>
  mutate(GPA = round(GPA * (4/10), 2))

# Converting number strings to numeric for Gender column 
Performance <- Performance |>
  mutate(Gender = ifelse(Gender == "Female", 1, 0))

# Deleting the "S" in Student_ID column so it's numeric
Performance$`Student_ID` <- as.numeric(gsub("S", "", unlist(Performance$`Student_ID`)))
